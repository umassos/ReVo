ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /home/umass/anaconda3/envs/pytorch/compiler_compat -fno-strict-overflow -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /home/umass/anaconda3/envs/pytorch/include -fPIC -O2 -isystem /home/umass/anaconda3/envs/pytorch/include -fPIC -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include/TH -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include/THC -I/usr/local/cuda/include -I/home/umass/anaconda3/envs/pytorch/include/python3.12 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=inference_extensions_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include/TH -I/home/umass/anaconda3/envs/pytorch/lib/python3.12/site-packages/torch/include/THC -I/usr/local/cuda/include -I/home/umass/anaconda3/envs/pytorch/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --use_fast_math --extra-device-vectorization -arch=native -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=inference_extensions_cuda -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/umass/Projects/neural_rgbd/dcvc/layers/extensions/inference/build/temp.linux-x86_64-cpython-312/bind.o: compile /home/umass/Projects/neural_rgbd/dcvc/layers/extensions/inference/bind.cpp
build /home/umass/Projects/neural_rgbd/dcvc/layers/extensions/inference/build/temp.linux-x86_64-cpython-312/impl.o: compile /home/umass/Projects/neural_rgbd/dcvc/layers/extensions/inference/impl.cpp
build /home/umass/Projects/neural_rgbd/dcvc/layers/extensions/inference/build/temp.linux-x86_64-cpython-312/kernel.o: cuda_compile /home/umass/Projects/neural_rgbd/dcvc/layers/extensions/inference/kernel.cu






